# Copier en .env et remplir les valeurs
LLM_API_KEY=your_github_models_token_here
LLM_BASE_URL=https://models.inference.ai.azure.com
LLM_MODEL=gpt-4o

APP_API_KEY=choose-a-strong-secret

# Authentification des comptes utilisateurs
AUTH_SECRET=choose-a-strong-random-secret
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=change-this-admin-password

PORT=3001
DB_PATH=./data/app.db

# Alertes RH (facultatif) — seuils des notifications retraite & turnover
RETIREMENT_AGE=60
FLIGHT_RISK_DAYS=15

EMPLOYEES_CSV=C:/path/to/details-employe.csv
ABSENCES_XLSX=C:/path/to/details_absence.xlsx
